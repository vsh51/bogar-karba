@model Web.Models.Author.AuthorChecklistsViewModel

@{
    ViewData["Title"] = "Author's Page";
}

<div class="author-page container mt-4" style="max-width: 800px;">
    <div class="mb-3">
        <a href="@Url.Action("Index", "Home")" class="text-dark text-decoration-none fs-4">
            <i class="bi bi-chevron-left"></i> <
        </a>
    </div>

    <h2 class="fw-normal mb-4">Your checklists :</h2>

    <div class="list-group list-group-flush">
        @if (!Model.Checklists.Any())
        {
            <div class="alert alert-light text-center border shadow-sm">
                <p class="mb-0 text-muted">You don't have any checklists yet. Click the button below to create your first one!</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Checklists)
            {
                <div class="list-group-item d-flex justify-content-between align-items-start border-0 px-0 mb-4">
                    <div class="ms-2 me-auto">
                        <div class="fw-bold">
                            <a href="@Url.Action("Show", "Checklist", new { id = item.Id })" class="text-decoration-none text-dark">@item.Title</a>
                            @if (!item.IsActive)
                            {
                                <span class="badge bg-secondary ms-2">inactive</span>
                            }
                        </div>
                        <div class="text-muted mt-1">
                            @item.Description
                        </div>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-link text-dark text-decoration-none fw-bold fs-4 p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            ...
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="@Url.Action("Edit", "Checklist", new { id = item.Id })">Edit checklist</a></li>
                            <li>
                                <form asp-action="Clone" asp-controller="Author" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item">Clone checklist</button>
                                </form>
                            </li>
                            <li>
                                <form asp-controller="Checklist" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this checklist?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">Delete checklist</button>
                                </form>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            @if (!item.IsActive)
                            {
                                <li>
                                    <form asp-controller="Author" asp-action="Activate" asp-route-id="@item.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">Activate checklist</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <form asp-controller="Author" asp-action="Deactivate" asp-route-id="@item.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">Deactivate checklist</button>
                                    </form>
                                </li>
                            }
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#" onclick="window.checklistProgressSync.copyShareLinkToClipboard('@item.Id'); return false;"><i class="bi bi-share"></i> Get shareable link</a></li>
                        </ul>
                    </div>
                </div>
            }
        }
    </div>

    <div class="mt-5">
        <a href="@Url.Action("Create", "Checklist")" class="btn btn-outline-secondary">
            Create new checklist
        </a>
    </div>
</div>

