@model List<Domain.Entities.Checklist>

@{
    ViewData["Title"] = "Admin Panel";
}

<div class="container mt-4" style="max-width: 800px;">
    <h2 class="fw-bold">Admin Panel</h2>
    <p class="text-muted">System management page</p>

    <form method="get" class="mb-4">
        <div class="input-group border rounded-pill overflow-hidden shadow-sm">
            <span class="input-group-text bg-white border-0"><i class="bi bi-search"></i></span>
            <input name="searchTerm" value="@ViewData["SearchTerm"]" class="form-control border-0 shadow-none" placeholder="Search..." />
            <button type="submit" class="btn btn-white border-0 px-4">Search</button>
        </div>
    </form>

    <div class="text-muted mb-3 ms-2 small">Search results:</div>

    <div class="list-group list-group-flush">
        @if (!Model.Any())
        {
            <div class="alert alert-light text-center">No results found for "@ViewData["SearchTerm"]"</div>
        }
        
        @foreach (var item in Model)
        {
            <div class="list-group-item d-flex justify-content-between align-items-start border-0 px-0 mb-4">
                <div class="ms-2 me-auto">
                    <div class="text-uppercase fw-bold" style="font-size: 0.9rem;">
                        <span class="text-muted">(Author: @item.UserId.ToString().Substring(0,5))</span> @item.Title
                    </div>
                    <div class="text-muted small">
                        @item.Description
                    </div>
                </div>
                
                <div class="dropdown">
                    <button class="btn btn-link text-dark text-decoration-none fw-bold" type="button" data-bs-toggle="dropdown">
                        ...
                    </button>
                    <ul class="dropdown-menu shadow border-0">
                        <li>
                            <form asp-controller="Admin" asp-action="Delete" asp-route-id="@item.Id" asp-route-searchTerm="@ViewData["SearchTerm"]" method="post"
                                  onsubmit="return confirm('Are you sure you want to delete this checklist?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">Delete checklist</button>
                            </form>
                        </li>
                        <li><a class="dropdown-item" href="#">Block account</a></li>
                    </ul>
                </div>
            </div>
        }
    </div>
</div>