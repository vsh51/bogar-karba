@model Web.Models.Admin.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a class="btn btn-outline-secondary" asp-controller="Admin" asp-action="Index">
                <i class="bi bi-arrow-left"></i> Back to Panel
            </a>
            <h2 class="mb-0">Admin Dashboard</h2>
        </div>
        
        <form asp-controller="Admin" asp-action="Logout" method="post" class="m-0">
            <button type="submit" class="btn btn-outline-danger">Logout</button>
        </form>
    </div>

    <div class="alert alert-success">
        <strong>Welcome, @User.Identity?.Name!</strong> You are logged in as an administrator.
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">System Overview</h5>
            <p class="card-text">Admin panel for managing checklists.</p>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="border rounded p-3 bg-light">
                        <h6>Total checklists</h6>
                        <strong>@Model.TotalChecklists</strong>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="border rounded p-3 bg-light">
                        <h6>Total users</h6>
                        <strong>@Model.TotalUsers</strong>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="border rounded p-3 bg-light">
                        <h6>Published</h6>
                        <strong>@Model.PublishedChecklists</strong>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="border rounded p-3 bg-light">
                        <h6>Drafts</h6>
                        <strong>@Model.DraftChecklists</strong>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="border rounded p-3 bg-light">
                        <h6>Archived</h6>
                        <strong>@Model.ArchivedChecklists</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
