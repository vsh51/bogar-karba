@model Web.Models.Checklist.ChecklistViewModel

@{
    ViewData["Title"] = Model.Title;
}

<style>
    .checklist-page {
        max-width: 760px;
        margin: 1.5rem auto 4rem;
        padding: 0 0.5rem;
    }

    .checklist-title {
        margin: 0 0 0.75rem;
        font-size: clamp(1.7rem, 2.2vw, 2.25rem);
        font-weight: 700;
        letter-spacing: 0.01em;
        line-height: 1.2;
    }

    .checklist-description {
        margin: 0 0 1.75rem;
        padding: 0.85rem 1rem;
        background: #f7f8fa;
        color: #5f646d;
        border-radius: 0.5rem;
        line-height: 1.45;
        white-space: pre-wrap;
    }

    .checklist-section {
        margin-top: 1.5rem;
        padding-top: 0.75rem;
        border-top: 1px solid #eceef2;
    }

    .checklist-section-title {
        margin: 0 0 0.7rem;
        font-size: 1.2rem;
        font-weight: 600;
        color: #3d4047;
    }

    .checklist-section-title::before {
        content: ">> ";
        color: #6c717a;
        font-weight: 500;
    }

    .checklist-items {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .checklist-item {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        margin: 0.45rem 0;
        color: #2f3339;
    }

    .checklist-item-input {
        margin-top: 0.24rem;
        width: 1rem;
        height: 1rem;
        flex: 0 0 auto;
    }

    .checklist-item-label {
        line-height: 1.35;
        margin: 0;
    }

    .checklist-empty {
        color: #6b7280;
        margin: 0.4rem 0 0;
    }
</style>

<section class="checklist-page">
    <header class="mb-3">
        <h1 class="checklist-title">@Model.Title</h1>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="checklist-description">@Model.Description</p>
        }
    </header>

    @if (Model.Sections.Any())
    {
        @foreach (var sec in Model.Sections.OrderBy(s => s.Position))
        {
            <article class="checklist-section">
                <h2 class="checklist-section-title">@sec.Name</h2>

                @if (sec.Items.Any())
                {
                    <ul class="checklist-items">
                        @foreach (var item in sec.Items)
                        {
                            var itemId = $"item-{item.Id}";

                            <li class="checklist-item">
                                <input id="@itemId" type="checkbox" class="form-check-input checklist-item-input" />
                                <label for="@itemId" class="checklist-item-label">@item.Content</label>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="checklist-empty">No items in this section yet.</p>
                }
            </article>
        }
    }
    else
    {
        <p class="checklist-empty">This checklist does not contain any sections yet.</p>
    }
</section>

