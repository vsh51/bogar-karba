@using Microsoft.Extensions.Options
@using Application.Options
@inject IOptions<ChecklistOptions> ChecklistOptionsAccessor
@{
    ViewData["Title"] = "Create Checklist";
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
    var maxDate = today.AddYears(ChecklistOptionsAccessor.Value.MaxDeadlineYears);
}

<style>
    .editor-content {
        display: flex;
        flex-direction: column;
    }

    .checklist-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.5rem;
        border-bottom: 1px solid #e9ecef;
    }

    .checklist-row:last-child {
        border-bottom: none;
    }

    .item-checkbox {
        width: 1rem;
        height: 1rem;
        border: 2px solid #adb5bd;
        border-radius: 0.2rem;
        flex-shrink: 0;
    }

    .item-input {
        flex: 1;
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.95rem;
    }

    .section-row {
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6 !important;
        margin-top: 0.25rem;
    }

    .section-input {
        flex: 1;
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .btn-delete {
        color: #dc3545;
        background: transparent;
        border: none;
        cursor: pointer;
        visibility: hidden;
        font-size: 1.1rem;
        line-height: 1;
    }

    .checklist-row:hover .btn-delete {
        visibility: visible;
    }
</style>

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-light text-center">
                <h4 class="mb-0">Create Checklist</h4>
            </div>
            <div class="card-body" id="checklist-editor">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control editable-title" placeholder="Enter checklist title" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <input type="text" class="form-control editable-desc" placeholder="Enter description (optional)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Deadline <span class="text-muted small">(optional)</span></label>
                    <input type="date" class="form-control editable-deadline"
                           min="@today.ToString("yyyy-MM-dd")"
                           max="@maxDate.ToString("yyyy-MM-dd")" />
                    <div class="form-text small">Maximum @ChecklistOptionsAccessor.Value.MaxDeadlineYears years ahead.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Items</label>
                    <div class="editor-content border rounded">
                        <div class="checklist-row">
                            <div class="item-checkbox"></div>
                            <input type="text" class="item-input" placeholder="Item description..." />
                            <button type="button" class="btn-delete">&times;</button>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="add-item-btn">+ Item</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="add-section-btn">+ Section</button>
                </div>

                <div class="d-grid">
                    <button type="button" class="btn btn-primary" id="create-checklist-btn">Create</button>
                </div>

                <div class="text-center mt-3">
                    <a asp-controller="Author" asp-action="Index">Back to your checklists</a>
                </div>

                @Html.AntiForgeryToken()
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/checklist-create.js"></script>
}
