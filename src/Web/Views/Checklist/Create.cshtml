<style>
    /* Checklist Editor Styles */
    :root {
        --primary-accent: #6366f1;
        --bg-surface: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --border-color: #e2e8f0;
    }

    .checklist-editor {
        max-width: 800px;
        margin: 2rem auto;
        padding: 2.5rem;
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .editor-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .back-btn {
        font-size: 1.5rem;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.5rem;
        border-radius: 0.75rem;
        transition: all 0.2s;
        border: none;
        background: transparent;
    }

    .back-btn:hover {
        background: #f1f5f9;
        color: var(--primary-accent);
    }

    .editable-title, .editable-desc {
        width: 100%;
        border: 1px solid transparent;
        padding: 0.5rem;
        border-radius: 0.5rem;
        transition: all 0.2s;
        cursor: pointer;
    }

    .editable-title {
        font-size: 2.25rem;
        font-weight: 700;
        color: var(--text-main);
        outline: none;
    }

    .editable-desc {
        font-size: 1.125rem;
        color: var(--text-muted);
        margin-bottom: 2rem;
        outline: none;
    }

    .editable-title:hover, .editable-desc:hover,
    .editable-title:focus, .editable-desc:focus {
        background: #f8fafc;
        border-color: var(--border-color);
    }

    .editor-content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .checklist-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.5rem;
        border-radius: 0.75rem;
        transition: all 0.2s;
    }

    .checklist-row:hover {
        background: #f8fafc;
    }

    .drag-handle {
        cursor: grab;
        color: #cbd5e1;
        font-size: 1.25rem;
        user-select: none;
        opacity: 0.4;
        transition: opacity 0.2s;
    }

    .checklist-row:hover .drag-handle {
        opacity: 1;
    }

    .custom-cb {
        width: 1.25rem;
        height: 1.25rem;
        border: 2px solid #cbd5e1;
        border-radius: 0.375rem;
        cursor: pointer;
        background: white;
    }

    .item-input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 1rem;
        color: var(--text-main);
        outline: none;
        padding: 0.25rem 0;
    }

    .section-row {
        margin-top: 1.5rem;
        font-weight: 600;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-bottom: 2px solid var(--border-color);
        padding: 0.5rem;
    }

    .section-prefix {
        color: var(--primary-accent);
        font-family: monospace;
    }

    .editor-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-color);
    }

    .btn-secondary-soft {
        background: #f1f5f9;
        color: #475569;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-secondary-soft:hover {
        background: #e2e8f0;
        color: #1e293b;
    }

    .btn-primary-custom {
        background: var(--primary-accent);
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 0.75rem;
        font-weight: 600;
        box-shadow: 0 4px 6px -1px rgba(99, 102, 241, 0.2);
        transition: all 0.2s;
    }

    .btn-primary-custom:hover {
        background: #4f46e5;
        transform: translateY(-1px);
        box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
    }

    .btn-delete {
        opacity: 0;
        color: #ef4444;
        background: transparent;
        border: none;
        padding: 0.25rem;
        border-radius: 0.375rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .checklist-row:hover .btn-delete {
        opacity: 1;
    }

    .btn-delete:hover {
        background: #fee2e2;
    }

    .section-input {
        font-size: 1.25rem;
        font-weight: 600;
        flex: 1;
        border: none;
        background: transparent;
        outline: none;
    }
</style>

<div class="checklist-editor" id="checklist-editor">
    <div class="editor-header">
        <a href="@Url.Action("Index", "Author")" class="back-btn"><i class="bi bi-arrow-left"></i></a>
        <div class="title-container">
            <h1 class="editable-title" contenteditable="true" data-placeholder="[ CLICK TO EDIT TITLE ]">[ CLICK TO EDIT TITLE ]</h1>
        </div>
    </div>

    <p class="editable-desc" contenteditable="true" data-placeholder="[ CLICK TO EDIT DESCRIPTION ]">[ CLICK TO EDIT DESCRIPTION ]</p>

    <div class="editor-content">
        <!-- Rows will be added here by JS -->
        <div class="checklist-row">
            <span class="drag-handle">::</span>
            <div class="custom-cb"></div>
            <input type="text" class="item-input" placeholder="item item item item item item item item" />
            <button type="button" class="btn-delete">×</button>
        </div>
    </div>

    <div class="editor-actions">
        <button type="button" class="btn-secondary-soft" id="add-item-btn">+Item</button>
        <button type="button" class="btn-secondary-soft" id="add-section-btn">+Section</button>
        <button type="button" class="btn-primary-custom" id="create-checklist-btn">Create</button>
    </div>

    @Html.AntiForgeryToken()
</div>

@section Scripts {
    <script src="~/js/checklist-create.js"></script>
}
