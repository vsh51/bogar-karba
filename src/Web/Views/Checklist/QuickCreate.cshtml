@{
    ViewData["Title"] = "Quick Create Checklist";
    const string QuickCreateExample = "# Trip to Lviv\n\nTwo-day weekend trip planning.\n\n## Before leaving\n- [ ] Buy train tickets\n- [ ] Charge power bank\n\n## In Lviv\n- [ ] Visit Rynok Square\n- [ ] Try Lviv coffee";
}

<style>
    .quick-create-rules {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 0.4rem;
        padding: 0.9rem 1rem;
        font-size: 0.9rem;
    }

    .quick-create-editor {
        display: flex;
        align-items: stretch;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
        background: #fff;
        overflow: hidden;
    }

    .quick-create-editor:focus-within {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, .25);
    }

    .quick-create-line-numbers {
        margin: 0;
        padding: 0.6rem 0.5rem;
        background: #f1f3f5;
        color: #868e96;
        text-align: right;
        user-select: none;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.9rem;
        line-height: 1.5;
        min-width: 2.6rem;
        overflow: hidden;
        white-space: pre;
        border-right: 1px solid #e9ecef;
    }

    #quick-create-text {
        flex: 1;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.9rem;
        line-height: 1.5;
        min-height: 18rem;
        padding: 0.6rem 0.8rem;
        border: none;
        border-radius: 0;
        resize: vertical;
    }

    #quick-create-text:focus {
        box-shadow: none;
        outline: none;
    }

    #quick-create-error {
        display: none;
    }
</style>

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-light text-center">
                <h4 class="mb-0">Quick Create Checklist</h4>
            </div>
            <div class="card-body">
                <div class="quick-create-rules mb-3">
                    <strong>Formatting rules</strong>
                    <ul class="mb-2 mt-2 ps-4">
                        <li>The first line must be the title: <code>#&nbsp;Title</code></li>
                        <li>Optional description lines may follow the title</li>
                        <li>Group items into sections with <code>##&nbsp;Section name</code></li>
                        <li>Each item starts with <code>-&nbsp;[&nbsp;]&nbsp;text</code> (the brackets are optional)</li>
                    </ul>
                </div>

                <div class="mb-3">
                    <label for="quick-create-text" class="form-label">Checklist text</label>
                    <div class="quick-create-editor">
                        <pre class="quick-create-line-numbers" id="quick-create-line-numbers" aria-hidden="true">1</pre>
                        <textarea id="quick-create-text" wrap="off" placeholder="Paste or type your checklist here...">@QuickCreateExample</textarea>
                    </div>
                </div>

                <div class="alert alert-danger" id="quick-create-error" role="alert"></div>

                <div class="d-grid">
                    <button type="button" class="btn btn-primary" id="quick-create-btn">Create</button>
                </div>

                <div class="text-center mt-3">
                    <a asp-controller="Checklist" asp-action="Create">Use the regular editor instead</a>
                    &middot;
                    <a asp-controller="Author" asp-action="Index">Back to your checklists</a>
                </div>

                @Html.AntiForgeryToken()
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/checklist-quick-create.js" asp-append-version="true"></script>
}
