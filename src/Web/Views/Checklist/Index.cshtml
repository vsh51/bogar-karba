@model IEnumerable<Domain.Entities.Checklist>

@{
    ViewData["Title"] = "Адмін-панель";
}

<div class="admin-container">
    <h1>Адмін-панель</h1>
    <p class="text-muted">Керування чеклистами користувачів</p>

    <div class="search-section">
        <input type="text" class="form-control search-input" placeholder="Пошук...">
        <span class="results-label">Всього знайдено: @Model.Count()</span>
    </div>

    <div class="checklist-list">
        @if (!Model.Any())
        {
            <div class="alert alert-info">Чеклистів поки що немає в базі даних.</div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="checklist-item" style="border: 1px solid #ddd; padding: 15px; margin-bottom: 10px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center;">
                    <div class="checklist-info">
                        <h5 class="checklist-title">
                            <strong>@item.Title</strong>
                        </h5>
                        <p class="checklist-description text-muted">@item.Description</p>
                    </div>
                    
                    <div class="checklist-actions dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Дії
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <form asp-controller="Checklist" asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                      onsubmit="return confirm('Ви впевнені, що хочете видалити цей чеклист?');">
                                    <button type="submit" class="dropdown-item text-danger">Видалити чеклист</button>
                                </form>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#">Блокувати автора</a></li>
                        </ul>
                    </div>
                </div>
            }
        }
    </div>
</div>